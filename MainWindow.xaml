<Window x:Class="VoltageDividerTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Voltage Divider Tool" Height="600" Width="680"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="icon.png">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar (Future use) -->
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0F1620" BorderBrush="#1C242F" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,20">
                <Border Width="32" Height="32" Background="{StaticResource AccentBrush}" CornerRadius="6" Margin="0,0,0,30">
                    <TextBlock Text="⚡" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Voltage Divider Button -->
                <Button x:Name="BtnModeDivider" Click="ChangeMode_Click" Tag="Divider" Background="Transparent" BorderThickness="0" Margin="0,1" Padding="0" HorizontalContentAlignment="Stretch">
                    <Border x:Name="BorderModeDivider" Height="54" Background="#1C242F" CornerRadius="0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="R" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="DIV" Foreground="White" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Parallel R Button -->
                <Button x:Name="BtnModeParallel" Click="ChangeMode_Click" Tag="Parallel" Background="Transparent" BorderThickness="0" Margin="0,1" Padding="0" HorizontalContentAlignment="Stretch">
                    <Border x:Name="BorderModeParallel" Height="54" Background="Transparent" CornerRadius="0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="R" Foreground="{StaticResource SecondaryTextBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="PAR" Foreground="{StaticResource SecondaryTextBrush}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>
                <!-- Regulator IC Button -->
                <Button x:Name="BtnModeRegulator" Click="ChangeMode_Click" Tag="Regulator" Background="Transparent" BorderThickness="0" Margin="0,1" Padding="0" HorizontalContentAlignment="Stretch">
                    <Border x:Name="BorderModeRegulator" Height="54" Background="Transparent" CornerRadius="0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="IC" Foreground="{StaticResource SecondaryTextBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="REG" Foreground="{StaticResource SecondaryTextBrush}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>
                <!-- Vnode Button -->
                <Button x:Name="BtnModeVnode" Click="ChangeMode_Click" Tag="Vnode" Background="Transparent" BorderThickness="0" Margin="0,1" Padding="0" HorizontalContentAlignment="Stretch">
                    <Border x:Name="BorderModeVnode" Height="54" Background="Transparent" CornerRadius="0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="V" Foreground="{StaticResource SecondaryTextBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="NODE" Foreground="{StaticResource SecondaryTextBrush}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>
                <!-- Color Code Button -->
                <Button x:Name="BtnModeColor" Click="ChangeMode_Click" Tag="ColorCode" Background="Transparent" BorderThickness="0" Margin="0,1" Padding="0" HorizontalContentAlignment="Stretch">
                    <Border x:Name="BorderModeColor" Height="54" Background="Transparent" CornerRadius="0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtModeColorTitle" Text="R" Foreground="{StaticResource SecondaryTextBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtModeColorSub" Text="COLOR" Foreground="{StaticResource SecondaryTextBrush}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>
                <!-- SMD Code Button -->
                <Button x:Name="BtnModeSmd" Click="ChangeMode_Click" Tag="SmdCode" Background="Transparent" BorderThickness="0" Margin="0,1" Padding="0" HorizontalContentAlignment="Stretch">
                    <Border x:Name="BorderModeSmd" Height="54" Background="Transparent" CornerRadius="0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="R" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="SMD" Foreground="{StaticResource SecondaryTextBrush}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header and Language Switch -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="MainHeader" Text="TÍNH CẦU PHÂN ÁP" Style="{StaticResource Header1}" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="20" Foreground="{StaticResource AccentBrush}"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Click="BtnGitHub_Click" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,16,0" Cursor="Hand" ToolTip="View on GitHub">
                         <Border Padding="12,0" Height="24" Background="#1C242F" CornerRadius="4" BorderBrush="#223042" BorderThickness="1">
                             <TextBlock x:Name="TxtAbout" Text="Thông tin" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                         </Border>
                    </Button>
                    <Button x:Name="BtnLangVi" Click="SwitchLang_Click" Tag="vi" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,8,0" Cursor="Hand">
                         <Border Width="36" Height="24" Background="#CC0000" CornerRadius="4" Opacity="0.8">
                             <TextBlock Text="VI" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                         </Border>
                    </Button>
                    <Button x:Name="BtnLangEn" Click="SwitchLang_Click" Tag="en" Background="Transparent" BorderThickness="0" Padding="0" Margin="0" Cursor="Hand">
                         <Border Width="36" Height="24" Background="#3C3B6E" CornerRadius="4" Opacity="0.8">
                             <TextBlock Text="EN" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                         </Border>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Dynamic Diagram -->
                <Border Grid.Column="0" Background="#141D29" CornerRadius="12" BorderBrush="#223042" BorderThickness="1" Margin="0,0,20,0">
                    <Grid>
                        <Viewbox Stretch="Uniform" Margin="20">
                            <Canvas x:Name="CircuitCanvas" Width="250" Height="600"/>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- Right Panel: Dynamic Inputs -->
                <Border Grid.Column="1" Background="#1C242F" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,-5,0">
                            <StackPanel x:Name="InputsStack" Margin="0,0,10,0">
                                <!-- Vin Row (Only for Divider) -->
                                <Grid x:Name="VinRow" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnCalcVin" Content="Vin" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                    <Grid Grid.Column="1">
                                        <TextBox x:Name="InputVin" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                        <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    </Grid>
                                </Grid>

                                <!-- Divider Mode Containers -->
                                <StackPanel x:Name="DividerPanel">
                                    <StackPanel x:Name="DividerResistorsContainer">
                                        <!-- Dynamic Resistor Rows -->
                                    </StackPanel>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnAddResistorDivider" Style="{StaticResource CalcButton}" Click="BtnAddResistor_Click" Tag="Divider" Width="75" Height="20" HorizontalAlignment="Left" BorderBrush="{StaticResource AccentBrush}" Foreground="{StaticResource AccentBrush}" Cursor="Hand">
                                            <TextBlock Text="+" FontSize="14" FontWeight="Bold" Margin="0,-3,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>

                                    <StackPanel x:Name="DividerResultsContainer" Margin="0,5,0,0">
                                        <!-- Dynamic Vout Results -->
                                    </StackPanel>
                                </StackPanel>

                                <!-- Parallel Mode Containers -->
                                <StackPanel x:Name="ParallelPanel" Visibility="Collapsed">
                                    <StackPanel x:Name="ParallelResistorsContainer">
                                        <!-- Dynamic Resistor Rows -->
                                    </StackPanel>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnAddResistorParallel" Style="{StaticResource CalcButton}" Click="BtnAddResistor_Click" Tag="Parallel" Width="75" Height="20" HorizontalAlignment="Left" BorderBrush="{StaticResource AccentBrush}" Foreground="{StaticResource AccentBrush}" Cursor="Hand">
                                            <TextBlock Text="+" FontSize="14" FontWeight="Bold" Margin="0,-3,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>

                                    <Grid x:Name="RTotalRow" Margin="0,5,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcRTotal" Content="Rtotal" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputRTotal" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8" Tag="RTotal"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Regulator Mode Container -->
                                <StackPanel x:Name="RegulatorPanel" Visibility="Collapsed">
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcRegVref" Content="Vref" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputVref" Style="{StaticResource ModernTextBox}" Text="1.25" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcRegR1" Content="R1" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputRegR1" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcRegR2" Content="R2" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputRegR2" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcRegVout" Content="Vout" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputRegVout" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>

                                <!-- Vnode Mode Container -->
                                <StackPanel x:Name="VnodePanel" Visibility="Collapsed">
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcVnodeV1" Content="V1" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputVnodeV1" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcVnodeV2" Content="V2" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputVnodeV2" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcVnodeR1" Content="R1" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputVnodeR1" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcVnodeR2" Content="R2" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputVnodeR2" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcVnodeR3" Content="R3" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputVnodeR3" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnCalcVnodeV3" Content="Vnode" Style="{StaticResource CalcButton}" Click="BtnCalc_Click" Width="75" HorizontalAlignment="Left"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="InputVnodeV3" Style="{StaticResource ModernTextBox}" Text="" TextChanged="Input_TextChanged" Padding="10,8,30,8"/>
                                            <Button Visibility="Collapsed" Click="Clear_Click" Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>

                                <!-- Color Code Mode Container -->
                                <StackPanel x:Name="ColorCodePanel" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                                        <RadioButton x:Name="Rb4Band" Content="4 Vòng" IsChecked="True" Foreground="White" Margin="0,0,15,0" Checked="BandToggle_Checked" Unchecked="BandToggle_Checked"/>
                                        <RadioButton x:Name="Rb5Band" Content="5 Vòng" Foreground="White" Margin="0,0,15,0" Checked="BandToggle_Checked" Unchecked="BandToggle_Checked"/>
                                        <RadioButton x:Name="Rb6Band" Content="6 Vòng" Foreground="White" Checked="BandToggle_Checked" Unchecked="BandToggle_Checked"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                                        <TextBlock x:Name="TxtColorResult" Text="0 Ω" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel VerticalAlignment="Center" Margin="0,4,0,0">
                                            <TextBlock x:Name="TxtColorTolerance" Text="±0%" FontSize="16" Foreground="#9CADC1" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="TxtColorTempCo" Text="100 ppm/K" FontSize="12" Foreground="#7E8C9E" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Selected Colors Visual Indicator mapped internally -->
                                    <Grid x:Name="ColorBandsGrid" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                                        <!-- Buttons populated via C# to avoid 100+ lines of XAML boilerplate -->
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                    </Grid>
                                </StackPanel>

                                <!-- SMD Code Mode Container -->
                                <StackPanel x:Name="SmdPanel" Visibility="Collapsed">
                                    <TextBlock x:Name="TxtSmdHeader" Text="NHẬP MÃ SMD (3 HOẶC 4 SỐ)" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                    <Grid Margin="0,0,0,20">
                                        <TextBox x:Name="InputSmdCode" Style="{StaticResource ModernTextBox}" FontSize="28" FontWeight="Bold" TextAlignment="Center" Height="65" MaxLength="4" TextChanged="InputSmdCode_TextChanged" Tag="SmdCode"/>
                                    </Grid>
                                    
                                    <Border Background="#141D29" CornerRadius="8" Padding="20" BorderBrush="#223042" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtSmdValueLabel" Text="GIÁ TRỊ ĐIỆN TRỞ" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtSmdResult" Text="0 Ω" FontSize="36" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <Button x:Name="ResetBtn" Grid.Row="1" Content="↺  ĐẶT LẠI" Style="{StaticResource ModernButton}" Height="45" Margin="0,15,0,0" Click="Reset_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
